      </datasource-dependencies>
      <datasource-dependencies datasource='federated.0jdj8au0hy8een1gxy8el0isfibj'>
        <column caption='State Name' datatype='string' name='[Calculation_0829360253743105]' role='dimension' semantic-role='[State].[Name]' type='nominal'>
          <calculation class='tableau' formula='IF [State] = &apos;CA&apos; THEN &apos;California&apos;&#13;&#10;ELSEIF [State] = &apos;CO&apos; THEN &apos;Colorado&apos;&#13;&#10;ELSEIF [State] = &apos;FL&apos; THEN &apos;Florida&apos;&#13;&#10;ELSEIF [State] = &apos;IL&apos; THEN &apos;Illinois&apos;&#13;&#10;ELSEIF [State] = &apos;MI&apos; THEN &apos;Michigan&apos;&#13;&#10;ELSEIF [State] = &apos;NY&apos; THEN &apos;New York&apos;&#13;&#10;ELSEIF [State] = &apos;OR&apos; THEN &apos;Oregon&apos;&#13;&#10;ELSEIF [State] = &apos;TX&apos; THEN &apos;Texas&apos;&#13;&#10;ELSEIF [State] = &apos;WA&apos; THEN &apos;Washington&apos;&#13;&#10;ELSE [State]&#13;&#10;END' />
        </column>
