    <dashboard enable-sort-zone-taborder='true' name='Sales Summary Dashboard'>
      <style />
      <size maxheight='1500' maxwidth='1500' minheight='1500' minwidth='1500' preset-index='17' sizing-mode='fixed' />
      <datasources>
        <datasource name='Parameters' />
        <datasource caption='Final Product &amp; Sales Data (Retail Data for Lab1)' name='federated.0jdj8au0hy8een1gxy8el0isfibj' />
      </datasources>
      <datasource-dependencies datasource='Parameters'>
        <column alias='Show' caption='Show/Hide Map' datatype='string' name='[Parameter 2]' param-domain-type='list' role='measure' type='nominal' value='&quot;Yes&quot;'>
          <calculation class='tableau' formula='&quot;Yes&quot;' />
          <aliases>
            <alias key='&quot;No&quot;' value='Hide' />
            <alias key='&quot;Yes&quot;' value='Show' />
          </aliases>
          <members>
            <member alias='Show' value='&quot;Yes&quot;' />
            <member alias='Hide' value='&quot;No&quot;' />
          </members>
        </column>
        <column caption='KPIs' datatype='string' name='[Parameter 3]' param-domain-type='list' role='measure' type='nominal' value='&quot;Orders&quot;'>
          <calculation class='tableau' formula='&quot;Orders&quot;' />
          <members>
            <member value='&quot;Quantity&quot;' />
            <member value='&quot;Orders&quot;' />
            <member value='&quot;Total Cost&quot;' />
            <member value='&quot;Profit&quot;' />
