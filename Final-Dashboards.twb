      <column aggregation='Sum' datatype='integer' name='[Age]' role='dimension' type='ordinal' />
      <column caption='State Name' datatype='string' name='[Calculation_0829360253743105]' role='dimension' semantic-role='[State].[Name]' type='nominal'>
        <calculation class='tableau' formula='IF [State] = &apos;CA&apos; THEN &apos;California&apos;&#13;&#10;ELSEIF [State] = &apos;CO&apos; THEN &apos;Colorado&apos;&#13;&#10;ELSEIF [State] = &apos;FL&apos; THEN &apos;Florida&apos;&#13;&#10;ELSEIF [State] = &apos;IL&apos; THEN &apos;Illinois&apos;&#13;&#10;ELSEIF [State] = &apos;MI&apos; THEN &apos;Michigan&apos;&#13;&#10;ELSEIF [State] = &apos;NY&apos; THEN &apos;New York&apos;&#13;&#10;ELSEIF [State] = &apos;OR&apos; THEN &apos;Oregon&apos;&#13;&#10;ELSEIF [State] = &apos;TX&apos; THEN &apos;Texas&apos;&#13;&#10;ELSEIF [State] = &apos;WA&apos; THEN &apos;Washington&apos;&#13;&#10;ELSE [State]&#13;&#10;END' />
      </column>
      <column caption='Gender Name' datatype='string' name='[Calculation_0829360254844930]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Gender] = &apos;F&apos; THEN &apos;Female&apos;&#13;&#10;ELSEIF [Gender] = &apos;M&apos; THEN &apos;Male&apos;&#13;&#10;ELSE [Gender]&#13;&#10;END' />
      </column>
      <column caption='Product Name Split' datatype='string' name='[Calculation_0829360257331203]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='SPLIT([Product_Name], &apos; &apos;, 1)' />
      </column>
      <column caption='Today' datatype='date' name='[Calculation_0829360259026948]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='TODAY()' />
      </column>
      <column caption='Yesterday' datatype='date' name='[Calculation_0829360259072005]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='TODAY() - 1' />
      </column>
      <column caption='First of Quarter' datatype='date' datatype-customized='true' name='[Calculation_0829360259325958]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATE(DATETRUNC(&apos;quarter&apos;,[Date] ))' />
      </column>
      <column caption='Rank' datatype='integer' name='[Calculation_0829360260243463]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK_DENSE(COUNT([__tableau_internal_object_id__].[Final Product &amp; Sales Data_E41AB12A9A404958B690BD7EAC144E60]), &apos;desc&apos;)'>
