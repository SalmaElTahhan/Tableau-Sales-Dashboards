      <column caption='KPIs Measure' datatype='real' name='[Calculation_1404680101871618]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 3] = &apos;Quantity&apos; THEN SUM([Quantity])&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &apos;Orders&apos; THEN COUNT([__tableau_internal_object_id__].[Final Product &amp; Sales Data_E41AB12A9A404958B690BD7EAC144E60])&#13;&#10;ELSEIF  [Parameters].[Parameter 3] = &apos;Total Cost&apos; THEN SUM([Calculation_1404680102400003])&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &apos;Profit&apos; THEN SUM([Calculation_1546241539063809])&#13;&#10;END' />
      </column>
      <column caption='Total Cost' datatype='real' name='[Calculation_1404680102400003]' role='measure' type='quantitative'>
